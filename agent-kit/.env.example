# Ritual testnet (chain 1979)
RITUAL_RPC_URL=https://rpc.ritualfoundation.org
CHAIN_ID=1979

# Your agent wallet private key (DO NOT SHARE, DO NOT COMMIT)
AGENT_PRIVATE_KEY=0x...

# For synthesis runner — uses AGENT_PRIVATE_KEY if not set separately
# SYNTHESIZER_PRIVATE_KEY=0x...

# LLM provider (OpenAI-compatible API)
LLM_API_KEY=sk-...
LLM_MODEL=gpt-4o
# Optional: use custom endpoint (e.g. Anthropic via compatible gateway)
# LLM_BASE_URL=

# Enable LLM-powered synthesis (Ritual precompile 0x0802).
# Leave unset to use contract-side fallback (basic concatenation).
# LLM_SYNTHESIS=1

# Agent profile
AGENT_NAME="Hivemind Agent"
# Comma-separated capabilities: research,code-review,market-analysis,fact-check
AGENT_CAPABILITIES=research,analysis

# Deployed contracts on Ritual testnet (chain 1979)
HIVE_CORE_ADDRESS=0xa5284207c3DA247D2c986c8434d6c0336Aa7d725
SWARM_EXECUTION_ADDRESS=0x937B181538Bd5dFDA8FFe62D82652CC4129F8F08
AGENT_REPUTATION_ADDRESS=0x884132e3bFC2c8A64f2f5DF32be0512b0B903D49

# Poll interval in milliseconds (defaults: agent=15s, synthesize=30s)
POLL_INTERVAL_MS=15000
# SYNTHESIS_POLL_MS=30000

# Max concurrent tasks this agent handles
MAX_CONCURRENT_TASKS=3

# Dependencies
node_modules/

# Build artifacts
cache/
artifacts/
.next/
web/.next/
web/node_modules/

# Ignition deployment state (auto-generated by Hardhat)
ignition/deployments/

# Temp scripts
scripts/fund-wallet.ts
scripts/test-hre.ts

# Ignore local/debug deployment records, but track named ones
# (e.g. ritual.json which is the official testnet deploy)
deployments/local-*.json
!deployments/ritual.json

# Env (all variants)
.env
.env.*
!.env.example
web/.env
web/.env.*
!web/.env.example

# Logs
*.log
backend-dev.err.log
backend-dev.out.log
backend-live.err.log
backend-live.out.log
web/dev-stderr.log
web/dev-stdout.log

# Temp files
_tmp_*.txt
_test.html
_check*.mjs

# Screenshots / preview images (keep public/ assets, ignore root pngs)
/web/*.png
/web/screenshot-*.png

# OS
Thumbs.db
.DS_Store
